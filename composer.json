{
    "name": "jeffersongoncalves/laravel-zero-credentials",
    "description": "Reusable base for storing CLI authentication credentials locally in JSON (~/.<app>/config.json or XDG), with 0600 permissions and a typed credentials contract.",
    "keywords": ["laravel-zero", "cli", "credentials", "auth", "json", "config"],
    "homepage": "https://github.com/jeffersongoncalves/laravel-zero-credentials",
    "license": "MIT",
    "authors": [
        { "name": "Jefferson Goncalves", "email": "jeffersongoncalves@users.noreply.github.com" }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.8|^4.1",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": { "JeffersonGoncalves\\LaravelZero\\Credentials\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "JeffersonGoncalves\\LaravelZero\\Credentials\\Tests\\": "tests/" }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test:lint": "pint --test",
        "test:types": "phpstan analyse",
        "test:unit": "pest",
        "test": ["@test:unit", "@test:lint"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "pestphp/pest-plugin": true }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
